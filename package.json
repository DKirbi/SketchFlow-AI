{
  "name": "transformer-patterns-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "lib",
    "demos/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-gateway.mjs",
    "dev:bracket-demo": "npm run dev -w bracket-demo",
    "dev:notifications-overview": "npm run dev -w notifications-overview",
    "dev:notifications-overview-hifi": "npm run dev -w notifications-overview-hifi",
    "build:lofi": "npm run build -w lofi-kit",
    "build:bracket-demo": "npm run build -w bracket-demo",
    "build:notifications-hifi": "npm run build -w notifications-overview-hifi",
    "build:all": "npm run demo-build",
    "demo-build": "node scripts/demo-build.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview:bracket-demo": "npm run preview -w bracket-demo",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "props:catalog": "node scripts/props-catalog.mjs",
    "props:catalog:md": "node scripts/props-catalog.mjs --emit-md",
    "test": "npm run test -w bracket-demo",
    "test:lib": "npm run test -w lofi-kit",
    "test:all": "npm run test:lib && npm run test",
    "test:watch": "npm run test:watch -w bracket-demo",
    "test:coverage": "npm run test -w bracket-demo -- --coverage",
    "ux-patterns:check": "node scripts/ux-patterns-process.mjs",
    "ux-patterns:watch": "node scripts/ux-patterns-watch.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/react": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar": "^4.0.3",
    "dayjs": "1.11.20",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-docgen-typescript": "^2.3.0",
    "sass": "^1.98.0",
    "storybook": "^10.3.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.1"
  },
  "dependencies": {}
}
