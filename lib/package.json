{
  "name": "lofi-kit",
  "version": "0.1.0",
  "description": "Lo-fi UI primitives and React Flow diagram blocks for fast prototyping",
  "type": "module",
  "main": "./dist/lofi-kit.cjs",
  "module": "./dist/lofi-kit.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lofi-kit.js",
      "require": "./dist/lofi-kit.cjs"
    },
    "./style.css": "./dist/lofi-kit.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "build-ts": "tsc -p tsconfig.build.json",
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@tanstack/react-table": ">=8.0.0",
    "@xyflow/react": ">=12.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "sass": "^1.98.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-select": "^2.2.6"
  }
}
